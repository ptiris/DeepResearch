# DeepResearch Environment Configuration
# Copy this file to .env and fill in your actual values
# Run: cp .env.example .env

# =============================================================================
# TORCH/NCCL Configuration (for multi-GPU setups)
# =============================================================================
TORCHDYNAMO_VERBOSE=1
TORCHDYNAMO_DISABLE=1
NCCL_IB_TC=16
NCCL_IB_SL=5
NCCL_IB_GID_INDEX=3
NCCL_SOCKET_IFNAME=eth
NCCL_DEBUG=INFO
NCCL_IB_HCA=mlx5
NCCL_IB_TIMEOUT=22
NCCL_IB_QPS_PER_CONNECTION=8
NCCL_MIN_NCHANNELS=4
NCCL_NET_PLUGIN=none
GLOO_SOCKET_IFNAME=eth0

# =============================================================================
# DeepResearch Configuration
# =============================================================================
QWEN_DOC_PARSER_USE_IDP=false
QWEN_IDP_ENABLE_CSI=false
NLP_WEB_SEARCH_ONLY_CACHE=false
NLP_WEB_SEARCH_ENABLE_READPAGE=false
NLP_WEB_SEARCH_ENABLE_SFILTER=false
QWEN_SEARCH_ENABLE_CSI=false
SPECIAL_CODE_MODE=false
PYTHONDONTWRITEBYTECODE=1

# =============================================================================
# OpenRouter API Configuration (replaces local vLLM deployment)
# =============================================================================
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek-ai/deepseek-prover-v2

# =============================================================================
# Inference Configuration
# =============================================================================
DATASET=your_dataset_name
OUTPUT_PATH=/your/output/path
ROLLOUT_COUNT=3
TEMPERATURE=0.85
PRESENCE_PENALTY=1.1
MAX_WORKERS=30

# =============================================================================
# Available Tools Configuration
# =============================================================================
# Comma-separated list of tool names to make available to the model
# Available tools: search (Serper), aliyun_search (Aliyun IQS), visit, google_scholar, PythonInterpreter, parse_file
# Example (Aliyun IQS): AVAILABLE_TOOLS=aliyun_search,visit,google_scholar,PythonInterpreter
# Example (Serper):      AVAILABLE_TOOLS=search,visit,google_scholar,PythonInterpreter
# Example (Both):       AVAILABLE_TOOLS=search,aliyun_search,visit,google_scholar,PythonInterpreter
AVAILABLE_TOOLS=aliyun_search,visit,google_scholar,PythonInterpreter

# =============================================================================
# Query Redundancy Reduction Configuration
# =============================================================================
# Enable query redundancy checking to reduce duplicate search queries
REDUNDANCY_ENABLED=False

# Strategy for handling redundant queries:
#   rephase - Ask the model to rephrase the queries (default)
#   skip    - Skip duplicate queries without execution
#   cache   - Use cached results from similar queries
REDUNDANCY_STRATEGY=rephase

# Scope for redundancy checking:
#   single_turn - Only check for duplicates within the current tool call (default)
#   global      - Check for duplicates across all queries in the solving session
REDUNDANCY_SCOPE=single_turn

# Similarity threshold (0.0-1.0) for considering queries as redundant
REDUNDANCY_SIMILARITY_THRESHOLD=0.8

# Maximum number of retries for rephase strategy
REDUNDANCY_MAX_RETRIES=2

# =============================================================================
# API Keys and External Services
# =============================================================================

# Serper API for web search and Google Scholar
# Get your key from: https://serper.dev/
SERPER_KEY_ID=your_key

# Aliyun IQS API for web search
# Get your key from: https://help.aliyun.com/zh/document_detail/2883041.html
ALIYUN_IQS_API_KEY=your_key

# Jina API for web page reading
# Get your key from: https://jina.ai/
JINA_API_KEYS=your_key

# Summary model API (OpenAI-compatible) for page summarization
# Get your key from: https://platform.openai.com/
API_KEY=your_key
API_BASE=your_api_base
SUMMARY_MODEL_NAME=your_summary_model_name

# Dashscope API for file parsing (PDF, Office, etc.)
# Get your key from: https://dashscope.aliyun.com/
# Supports: qwen-omni-turbo, qwen-plus-latest
DASHSCOPE_API_KEY=your_key
DASHSCOPE_API_BASE=your_api_base
VIDEO_MODEL_NAME=your_video_model_name
VIDEO_ANALYSIS_MODEL_NAME=your_analysis_model_name

# =============================================================================
# Python Code Execution Sandbox
# =============================================================================

# SandboxFusion endpoints for Python interpreter
# Example: "http://22.16.67.220:8080,http://22.16.78.153:8080,http://22.17.10.216:8080"
# See: https://github.com/bytedance/SandboxFusion
SANDBOX_FUSION_ENDPOINT=your_sandbox_endpoint
TORCH_COMPILE_CACHE_DIR=./cache

# =============================================================================
# IDP Service (Advanced File Parsing - Optional)
# =============================================================================

# IDP service for enhanced file parsing
# Set USE_IDP=True and provide credentials for more powerful parsing
# Documentation: https://help.aliyun.com/zh/document-mind/developer-reference/use-idp-llm-to-complete-document-summary
USE_IDP=False
IDP_KEY_ID=your_idp_key_id
IDP_KEY_SECRET=your_idp_key_secret

# =============================================================================
# Multi-Worker Configuration (Optional)
# =============================================================================

# These are typically set by distributed training frameworks
# WORLD_SIZE=1
# RANK=0
